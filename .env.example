# Server Port
PORT=3000

# Server Host Binding (defaults to 127.0.0.1 for security)
# Set to 0.0.0.0 to expose the terminal to your local network or the internet.
# Note: Changing this from 127.0.0.1 WILL REQUIRE NEXTERM_USER/PASSWORD to be set!
HOST=127.0.0.1

# Environment (development/production)
NODE_ENV=production

# Authentication Secret (auto-generated on first run if not set)
# Generate manually with: openssl rand -hex 32
SECRET_TOKEN=change_this_to_a_secure_random_string

# Shell Override — set this to use a specific shell instead of auto-detection
# Windows examples:
#   NEXTERM_SHELL=powershell.exe   ← Windows PowerShell (default on Windows)
#   NEXTERM_SHELL=pwsh.exe         ← PowerShell 7 (if installed)
#   NEXTERM_SHELL=cmd.exe          ← Classic Command Prompt
# Linux/macOS examples:
#   NEXTERM_SHELL=/bin/bash        ← Bash (default on Linux)
#   NEXTERM_SHELL=/bin/zsh         ← Zsh (default on macOS)
#   NEXTERM_SHELL=/usr/bin/fish    ← Fish shell
# NEXTERM_SHELL=

# Security / CORS Limits
# ALLOWED_ORIGINS=http://localhost:3000,https://nexterm.yourdomain.com

# ── Password Protection ────────────────────────────────────────────────────────
# Set BOTH variables to enable a login screen before the terminal.
# If either is left blank/unset, the terminal is open to anyone who can reach it.
#
# NEXTERM_USER=admin
# NEXTERM_PASSWORD=changeme

# Override: If you host NexTerm on the network (HOST=0.0.0.0) without setting
# a username and password above, the server will intentionally crash for your safety.
# Set this to "true" to bypass that check and keep the terminal fully open globally.
# ALLOW_UNAUTHENTICATED=false
