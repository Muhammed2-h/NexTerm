# Server Port
PORT=3000

# Environment (development/production)
NODE_ENV=production

# Authentication Secret (REQUIRED for securing terminal access and JWT)
# Generate a strong token with: openssl rand -hex 32
SECRET_TOKEN=change_this_to_a_secure_random_string


# Optional PTY Configuration
# MAX_HISTORY_SIZE=1000

# Security / CORS Limits
# ALLOWED_ORIGINS=http://localhost:3000,http://100.X.X.X,https://nexterm.internal
