{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": false,
    "outDir": "./dist/server",
    "rootDir": "./"
  },
  "include": ["server.ts", "src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "node_modules", "dist"]
}
